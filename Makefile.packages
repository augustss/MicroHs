	$(MINST) --git="https://github.com/konsumlamm/bimap.git --branch=mhs" bimap
	$(MINST) byteable
	$(MINST) bytestring-builder
	$(MINST) casing
	$(MINST) composition
	$(MINST) cpu
	$(MINST) data-ordlist
	$(MINST) --git="https://github.com/konsumlamm/dlist.git --branch=mhs" dlist
