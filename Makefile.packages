	$(MINST) --git=https://github.com/MicroHs/indexed-traversable-mhs.git --dir=indexed-traversable indexed-traversable
	$(MINST) parallel
	$(MINST) newtype
	$(MINST) Diff
	$(MINST) void
	$(MINST) character-ps
	$(MINST) contravariant
